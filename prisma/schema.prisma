generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
}

enum InvoiceStatus {
  draft
  sent
  paid
  unpaid
  overdue
  cancelled
}

enum WorkspaceRole {
  owner
  admin
  accountant
  viewer
}

enum RecurrenceFrequency {
  weekly
  monthly
  yearly
}

enum BudgetPeriod {
  monthly
  quarterly
  yearly
}

enum VerificationPurpose {
  email_verification
  login
}

model User {
  id                String                    @id @default(cuid())
  email             String                    @unique
  username          String?                   @unique
  phoneNumber       String?
  password          String
  emailVerifiedAt   DateTime?
  transactions      Transaction[]
  invoices          Invoice[]
  preference        UserPreference?
  trackingFolders   FinancialTrackingFolder[]
  ownedWorkspaces   Workspace[]               @relation("WorkspaceOwner")
  workspaceMembers  WorkspaceMember[]
  verificationCodes EmailVerificationCode[]
}

model EmailVerificationCode {
  id         String              @id @default(cuid())
  userId     String
  codeHash   String
  purpose    VerificationPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int                 @default(0)
  createdAt  DateTime            @default(now())
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
  @@index([expiresAt])
}

model UserPreference {
  id                   String     @id @default(cuid())
  userId               String     @unique
  activeWorkspaceId    String?
  currency             String     @default("USD")
  startingBalance      Decimal    @default(0) @db.Decimal(12, 2)
  monthlyFixedExpenses Decimal    @default(0) @db.Decimal(12, 2)
  onboardingComplete   Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeWorkspace      Workspace? @relation(fields: [activeWorkspaceId], references: [id], onDelete: SetNull)

  @@index([activeWorkspaceId])
}

model Workspace {
  id                    String                    @id @default(cuid())
  ownerId               String
  name                  String
  currency              String                    @default("USD")
  startingBalance       Decimal                   @default(0) @db.Decimal(12, 2)
  monthlyFixedExpenses  Decimal                   @default(0) @db.Decimal(12, 2)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  owner                 User                      @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members               WorkspaceMember[]
  transactions          Transaction[]
  invoices              Invoice[]
  trackingFolders       FinancialTrackingFolder[]
  recurringTransactions RecurringTransaction[]
  budgets               CategoryBudget[]
  preferences           UserPreference[]

  @@index([ownerId])
  @@index([ownerId, createdAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(viewer)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model FinancialTrackingFolder {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String?
  name        String
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  workspaceId String?
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  category    String
  date        DateTime
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([workspaceId])
  @@index([workspaceId, date])
  @@index([workspaceId, category])
}

model Invoice {
  id           String        @id @default(cuid())
  userId       String
  workspaceId  String?
  clientName   String
  amount       Decimal       @db.Decimal(12, 2)
  dueDate      DateTime
  reminderDate DateTime?
  status       InvoiceStatus @default(unpaid)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, dueDate])
  @@index([workspaceId])
  @@index([workspaceId, dueDate])
  @@index([workspaceId, status])
}

model RecurringTransaction {
  id          String              @id @default(cuid())
  workspaceId String
  name        String
  type        TransactionType
  amount      Decimal             @db.Decimal(12, 2)
  category    String
  frequency   RecurrenceFrequency
  nextDate    DateTime
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, nextDate])
  @@index([workspaceId, active])
}

model CategoryBudget {
  id          String       @id @default(cuid())
  workspaceId String
  category    String
  amount      Decimal      @db.Decimal(12, 2)
  period      BudgetPeriod @default(monthly)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, category, period])
  @@index([workspaceId])
}
