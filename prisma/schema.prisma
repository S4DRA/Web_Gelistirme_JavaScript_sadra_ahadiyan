generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
}

enum InvoiceStatus {
  paid
  unpaid
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  transactions Transaction[]
  invoices     Invoice[]
}

model Transaction {
  id       String          @id @default(cuid())
  userId   String
  type     TransactionType
  amount   Decimal         @db.Decimal(12, 2)
  category String
  date     DateTime
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model Invoice {
  id         String        @id @default(cuid())
  userId     String
  clientName String
  amount     Decimal       @db.Decimal(12, 2)
  dueDate    DateTime
  status     InvoiceStatus
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, dueDate])
}
