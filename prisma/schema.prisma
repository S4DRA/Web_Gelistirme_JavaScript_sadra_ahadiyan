generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  income
  expense
}

enum InvoiceStatus {
  draft
  sent
  paid
  unpaid
  overdue
  cancelled
}

enum WorkspaceRole {
  owner
  admin
  accountant
  viewer
}

enum RecurrenceFrequency {
  weekly
  monthly
  yearly
}

enum BudgetPeriod {
  monthly
  quarterly
  yearly
}

model User {
  id               String                    @id @default(cuid())
  email            String                    @unique
  username         String?                   @unique
  phoneNumber      String?
  profileImage     String?
  password         String
  transactions     Transaction[]
  invoices         Invoice[]
  preference       UserPreference?
  emailChangeCodes EmailChangeVerificationCode[]
  trackingFolders  FinancialTrackingFolder[]
  ownedWorkspaces  Workspace[]               @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[]
}

model SignupVerificationCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  attempts   Int       @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
  @@index([expiresAt])
  @@index([email, consumedAt, expiresAt])
}

model SignupRequest {
  id                String    @id @default(cuid())
  email             String
  fullName          String
  country           String
  phoneNumber       String
  companyName       String?
  companyWebsite    String?
  note              String?
  source            String
  approvalTokenHash String    @unique
  inviteTokenHash   String?   @unique
  approvedAt        DateTime?
  inviteSentAt      DateTime?
  usedAt            DateTime?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())

  @@index([email, createdAt])
  @@index([email, approvedAt, usedAt, expiresAt])
  @@index([expiresAt])
}

model EmailChangeVerificationCode {
  id         String    @id @default(cuid())
  userId     String
  email      String
  codeHash   String
  attempts   Int       @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([expiresAt])
  @@index([userId, email, consumedAt, expiresAt])
}

model UserPreference {
  id                   String     @id @default(cuid())
  userId               String     @unique
  activeWorkspaceId    String?
  currency             String     @default("USD")
  dashboardLayout      Json?
  predictionSettings   Json?
  startingBalance      Decimal    @default(0) @db.Decimal(12, 2)
  monthlyFixedExpenses Decimal    @default(0) @db.Decimal(12, 2)
  onboardingComplete   Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeWorkspace      Workspace? @relation(fields: [activeWorkspaceId], references: [id], onDelete: SetNull)

  @@index([activeWorkspaceId])
}

model Workspace {
  id                    String                    @id @default(cuid())
  ownerId               String
  name                  String
  currency              String                    @default("USD")
  startingBalance       Decimal                   @default(0) @db.Decimal(12, 2)
  monthlyFixedExpenses  Decimal                   @default(0) @db.Decimal(12, 2)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  owner                 User                      @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members               WorkspaceMember[]
  transactions          Transaction[]
  invoices              Invoice[]
  trackingFolders       FinancialTrackingFolder[]
  recurringTransactions RecurringTransaction[]
  budgets               CategoryBudget[]
  preferences           UserPreference[]

  @@index([ownerId])
  @@index([ownerId, createdAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(viewer)
  createdAt   DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model FinancialTrackingFolder {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String?
  name        String
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

model Transaction {
  id               String          @id @default(cuid())
  userId           String
  workspaceId      String?
  type             TransactionType
  amount           Decimal         @db.Decimal(12, 2)
  category         String
  date             DateTime
  note             String?
  currency         String          @default("USD")
  originalAmount   Decimal?        @db.Decimal(12, 2)
  originalCurrency String?
  exchangeRate     Decimal?        @db.Decimal(18, 8)
  importFingerprint String?
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([workspaceId])
  @@index([workspaceId, date])
  @@index([workspaceId, category])
  @@index([workspaceId, importFingerprint])
}

model Invoice {
  id               String        @id @default(cuid())
  userId           String
  workspaceId      String?
  clientName       String
  amount           Decimal       @db.Decimal(12, 2)
  dueDate          DateTime
  reminderDate     DateTime?
  status           InvoiceStatus @default(unpaid)
  currency         String        @default("USD")
  originalAmount   Decimal?      @db.Decimal(12, 2)
  originalCurrency String?
  exchangeRate     Decimal?      @db.Decimal(18, 8)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, dueDate])
  @@index([workspaceId])
  @@index([workspaceId, dueDate])
  @@index([workspaceId, status])
}

model RecurringTransaction {
  id          String              @id @default(cuid())
  workspaceId String
  name        String
  type        TransactionType
  amount      Decimal             @db.Decimal(12, 2)
  category    String
  currency    String              @default("USD")
  frequency   RecurrenceFrequency
  nextDate    DateTime
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, nextDate])
  @@index([workspaceId, active])
}

model CategoryBudget {
  id          String       @id @default(cuid())
  workspaceId String
  category    String
  amount      Decimal      @db.Decimal(12, 2)
  period      BudgetPeriod @default(monthly)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, category, period])
  @@index([workspaceId])
}
